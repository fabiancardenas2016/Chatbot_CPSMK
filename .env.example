# Copia este archivo a ".env" (en la raíz del proyecto o dentro de backend/)
# y coloca tu clave gratuita de Google AI Studio: https://aistudio.google.com/apikey

GOOGLE_API_KEY=coloca_aqui_tu_api_key_gratuita

# Modelos (opcional, ya traen un valor por defecto gratuito)
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=models/gemini-embedding-001

# Parámetros del RAG (opcional)
CHUNK_SIZE=1600
CHUNK_OVERLAP=150
RETRIEVER_SCORE_THRESHOLD=0.3
RETRIEVER_K=4

# Servidor (opcional)
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO
